# ============================================================
#  Variables d'environnement de la plateforme bancaire.
#  Copier ce fichier en .env puis adapter les valeurs.
#      cp .env.example .env
#  Le fichier .env est ignore par Git (ne JAMAIS le committer).
# ============================================================

# --- Base de donnees PostgreSQL ---
DB_USER=bank
DB_PASSWORD=bank

# --- Broker de messages RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Securite JWT (auth-service) ---
# Cle de signature des jetons : >= 256 bits. A CHANGER imperativement.
JWT_SECRET=change-me-une-cle-secrete-de-256-bits-minimum-pour-le-tp-inf46

# --- Connexion Google (auth-service) ---
# ID client OAuth 2.0 cree dans Google Cloud Console (type "Application Web").
# Laisser vide desactive le bouton "Se connecter avec Google".
GOOGLE_CLIENT_ID=
